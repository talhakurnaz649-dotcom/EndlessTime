@model IEnumerable<EndlessTime.Model.Entities.User>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Endless Time - Yetki Yönetimi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" />
    <style>
            body {
                background-color: #0b0b0b;
                color: #e5e5e5;
                display: flex;
            }

            .sidebar {
                width: 260px;
                background-color: #111;
                border-right: 1px solid rgba(212,175,55,0.25);
                padding: 25px 15px;
                position: fixed;
                height: 100vh;
                display: flex;
                flex-direction: column;
            }

            .sidebar-brand {
                font-family: Georgia, serif;
                font-size: 1.5rem;
                color: #d4af37;
                text-align: center;
                margin-bottom: 35px;
                letter-spacing: 2px;
                border-bottom: 1px solid rgba(212,175,55,0.2);
                padding-bottom: 15px;
            }

            .sidebar-link {
                color: #ccc;
                text-decoration: none;
                padding: 12px 15px;
                border-radius: 8px;
                margin-bottom: 8px;
                display: flex;
                align-items: center;
                gap: 12px;
            }

                .sidebar-link:hover, .sidebar-link.active {
                    background-color: rgba(212,175,55,0.15);
                    color: #d4af37;
                    border-left: 3px solid #d4af37;
                }

            .main-content {
                margin-left: 260px;
                padding: 40px;
                width: calc(100% - 260px);
            }

            .panel-card {
                background-color: #121212;
                border: 1px solid rgba(212, 175, 55, 0.15);
                border-radius: 10px;
                padding: 25px;
            }

            .table-luxury {
                background-color: #121212 !important;
                color: #e0e0e0 !important;
            }

                .table-luxury th {
                    color: #d4af37 !important;
                    border-bottom: 2px solid #d4af37 !important;
                }

                .table-luxury td {
                    border-bottom: 1px solid rgba(212,175,55,0.1) !important;
                }
    </style>
</head>
<body>

    <!-- SOL SABİT MENÜ -->
    <div class="sidebar">
        <div class="sidebar-brand">ENDLESS TIME</div>
        <a href="/Admin/Product/Index" class="sidebar-link">📊 Kontrol Paneli</a>
        <a href="/Admin/Product/Create" class="sidebar-link">➕ Yeni Saat Ekle</a>
        <a href="/Admin/User/Index" class="sidebar-link active">👥 Kullanıcılar</a>
        <a href="/Admin/Order" class="sidebar-link">📦 Sipariş Raporları</a>
        <a href="/Admin/Log" class="sidebar-link">⚙️ Sistem Günlükleri</a>

        <a href="/Home" class="sidebar-link" style="margin-top: auto; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 15px;">🏠 Mağaza Ön Yüzü</a>
        <a href="/Account/Logout" class="sidebar-link text-danger">🔒 Çıkış Yap</a>
    </div>

    <!-- SAĞ ANA İÇERİK ALANI -->
    <div class="main-content">
        <div class="mb-5 border-bottom pb-3" style="border-color: rgba(212,175,55,0.2) !important;">
            <h2 style="font-family: Georgia, serif;">Müşteri & Yetki Yönetimi</h2>
            <small class="text-muted">Kayıtlı kullanıcıların yetki seviyelerini buradan atayabilirsiniz.</small>
        </div>

        <div class="card panel-card p-4">
            <h4 class="mb-4 text-warning" style="font-family: Georgia, serif;">Sistem Üye Detayları</h4>
            <div class="table-responsive">
                <table class="table table-luxury table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Adı Soyadı</th>
                            <th>İletişim</th>
                            <th>Rol Seviyesi</th>
                            <th>Yetki Düzenle</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            var roleBadge = "bg-secondary text-white";
                            var roleLabel = "1. Seviye (Müşteri)";

                            if (user.Role == "Admin")
                            {
                                roleBadge = "bg-danger text-white";
                                roleLabel = "3. Seviye (Admin)";
                            }
                            else if (user.Role == "Moderator")
                            {
                                roleBadge = "bg-warning text-dark";
                                roleLabel = "2. Seviye (Moderatör)";
                            }

                            <tr>
                                <td class="fw-bold text-white">@user.FullName</td>
                                <td>
                                    <div class="small">@user.Email</div>
                                    <div class="small text-muted">@(user.PhoneNumber ?? "Telefon Yok")</div>
                                </td>
                                <td><span class="badge @roleBadge">@roleLabel</span></td>
                                <td>
                                    <!-- Yetki Seviyesi Seçme Formu 🚨 -->
                                    <form action="/Admin/User/UpdateRole" method="post" class="d-flex align-items-center gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <select name="newRole" class="form-select form-select-sm" style="background:#222; color:#fff; border:1px solid #d4af37; max-width:160px;">
                                            <!option value="User" @(user.Role == "User" ? "selected" : "")>1. Seviye (Müşteri)</!option>
                                            <!option value="Moderator" @(user.Role == "Moderator" ? "selected" : "")>2. Seviye (Moderatör)</!option>
                                            <!option value="Admin" @(user.Role == "Admin" ? "selected" : "")>3. Seviye (Admin)</!option>
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-warning">Yetkilendir ⚡</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</body>
</html>