@model IEnumerable<EndlessTime.Model.Entities.Order>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Endless Time - Sipariş Yönetimi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" />
    <style>
            body {
                background-color: #0b0b0b;
                color: #e5e5e5;
                display: flex;
            }

            .sidebar {
                width: 260px;
                background-color: #111;
                border-right: 1px solid rgba(212,175,55,0.25);
                padding: 25px 15px;
                position: fixed;
                height: 100vh;
                display: flex;
                flex-direction: column;
            }

            .sidebar-brand {
                font-family: Georgia, serif;
                font-size: 1.5rem;
                color: #d4af37;
                text-align: center;
                margin-bottom: 35px;
                letter-spacing: 2px;
                border-bottom: 1px solid rgba(212,175,55,0.2);
                padding-bottom: 15px;
            }

            .sidebar-link {
                color: #ccc;
                text-decoration: none;
                padding: 12px 15px;
                border-radius: 8px;
                margin-bottom: 8px;
                display: flex;
                align-items: center;
                gap: 12px;
            }

                .sidebar-link:hover, .sidebar-link.active {
                    background-color: rgba(212,175,55,0.15);
                    color: #d4af37;
                    border-left: 3px solid #d4af37;
                }

            .main-content {
                margin-left: 260px;
                padding: 40px;
                width: calc(100% - 260px);
            }

            .panel-card {
                background-color: #121212;
                border: 1px solid rgba(212, 175, 55, 0.15);
                border-radius: 10px;
                padding: 25px;
            }

            .table-luxury {
                background-color: #121212 !important;
                color: #e0e0e0 !important;
            }

                .table-luxury th {
                    color: #d4af37 !important;
                    border-bottom: 2px solid #d4af37 !important;
                }

                .table-luxury td {
                    border-bottom: 1px solid rgba(212,175,55,0.1) !important;
                }
    </style>
</head>
<body>

    <!-- SOL SABİT MENÜ (SENKRONİZE EDİLDİ 🚨) -->
    <div class="sidebar">
        <div class="sidebar-brand">ENDLESS TIME</div>
        <a href="/Admin/Product/Index" class="sidebar-link">📊 Kontrol Paneli</a>

        @if (User.IsInRole("Admin"))
        {
            <a href="/Admin/Product/Create" class="sidebar-link">➕ Yeni Saat Ekle</a>
            <a href="/Admin/User/Index" class="sidebar-link">👥 Kullanıcılar</a>
        }

        <a href="/Admin/Order" class="sidebar-link active">📦 Sipariş Raporları</a>

        @if (User.IsInRole("Admin"))
        {
            <a href="/Admin/Log" class="sidebar-link">⚙️ Sistem Günlükleri</a>
        }

        <a href="/Home" class="sidebar-link" style="margin-top: auto; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 15px;">🏠 Mağaza Ön Yüzü</a>
        <a href="/Account/Logout" class="sidebar-link text-danger">🔒 Çıkış Yap</a>
    </div>

    <!-- SAĞ ANA İÇERİK ALANI -->
    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-5 border-bottom pb-3" style="border-color: rgba(212,175,55,0.2) !important;">
            <div>
                <h2 style="font-family: Georgia, serif;">Sipariş Raporları & Kargo Süreci</h2>
                <small class="text-muted">Sipariş durumunu değiştirerek müşteriye canlı bilgi sağlayın.</small>
            </div>
            <div>
                <!-- Sadece Admin Manuel Sipariş Ekleme Butonunu Görür 🚨 -->
                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/Order/Create" class="btn btn-warning me-2 fw-bold text-dark" style="background-color:#d4af37; border:none;">➕ Yeni Sipariş Ekle</a>
                }
                <a href="/Admin/Order/ExportToExcel" class="btn btn-outline-warning me-2">📊 Excel'e Aktar</a>
                <a href="/Admin/Order/ExportToPdf" class="btn btn-outline-light">📄 PDF Rapor Al</a>
            </div>
        </div>

        <div class="card panel-card p-4">
            <h4 class="mb-4 text-warning" style="font-family: Georgia, serif;">Sipariş Süreç Kontrolü</h4>
            <div class="table-responsive">
                <table class="table table-luxury table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Sipariş No</th>
                            <th>Sipariş Tarihi</th>
                            <th>Toplam Tutar</th>
                            <th>Kargo Takip Durumu</th>
                            <th>Durumu Güncelle</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var statusBadge = "bg-secondary";
                            if (item.Status == "Hazırlanıyor") statusBadge = "bg-warning text-dark";
                            else if (item.Status == "Yola Çıktı") statusBadge = "bg-primary";
                            else if (item.Status == "Teslim Edildi") statusBadge = "bg-success";

                            <tr>
                                <td class="fw-bold">#@item.Id</td>
                                <td>@item.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="text-success fw-bold">@item.TotalAmount.ToString("N0") TL</td>
                                <td><span class="badge @statusBadge">@item.Status</span></td>
                                <td>
                                    <!-- Sipariş Durumu Seçme Formu -->
                                    <form action="/Admin/Order/UpdateStatus" method="post" class="d-flex align-items-center gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="orderId" value="@item.Id" />
                                        <select name="newStatus" class="form-select form-select-sm" style="background:#222; color:#fff; border:1px solid #d4af37; max-width:160px;">
                                            <!option value="Sipariş Verildi" @(item.Status == "Sipariş Verildi" ? "selected" : "")>📝 Sipariş Verildi</!option>
                                            <!option value="Hazırlanıyor" @(item.Status == "Hazırlanıyor" ? "selected" : "")>📦 Hazırlanıyor</!option>
                                            <!option value="Yola Çıktı" @(item.Status == "Yola Çıktı" ? "selected" : "")>🚚 Yola Çıktı</!option>
                                            <!option value="Teslim Edildi" @(item.Status == "Teslim Edildi" ? "selected" : "")>✅ Teslim Edildi</!option>
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-outline-warning">Güncelle</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</body>
</html>