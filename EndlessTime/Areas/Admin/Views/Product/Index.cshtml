@model IEnumerable<EndlessTime.Model.Entities.Product>

@{
    Layout = null;

    var automaticCount = Model.Count(p => p.CategoryId == 1);
    var pocketCount = Model.Count(p => p.CategoryId == 2);
    var sportCount = Model.Count(p => p.CategoryId == 3);
    var smartCount = Model.Count(p => p.CategoryId == 4);
    var womenCount = Model.Count(p => p.CategoryId == 5);
    var menCount = Model.Count(p => p.CategoryId == 6);

    decimal totalStockValue = Model.Sum(p => p.Price * p.Stock);
    decimal totalSalesAmount = ViewBag.TotalSales != null ? (decimal)ViewBag.TotalSales : 0;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Endless Time - Admin Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" />

    <style>
            body {
                background-color: #0b0b0b;
                color: #e5e5e5;
                font-family: 'Inter', sans-serif;
                margin: 0;
                display: flex;
                min-height: 100vh;
            }

            .sidebar {
                width: 260px;
                background-color: #111;
                border-right: 1px solid rgba(212, 175, 55, 0.25);
                padding: 25px 15px;
                display: flex;
                flex-direction: column;
                position: fixed;
                height: 100vh;
            }

            .sidebar-brand {
                font-family: Georgia, serif;
                font-size: 1.5rem;
                color: #d4af37;
                text-align: center;
                margin-bottom: 35px;
                letter-spacing: 2px;
                border-bottom: 1px solid rgba(212, 175, 55, 0.2);
                padding-bottom: 15px;
            }

            .sidebar-link {
                color: #ccc;
                text-decoration: none;
                padding: 12px 15px;
                border-radius: 8px;
                margin-bottom: 8px;
                display: flex;
                align-items: center;
                gap: 12px;
                font-size: 0.95rem;
                transition: all 0.2s;
            }

                .sidebar-link:hover, .sidebar-link.active {
                    background-color: rgba(212, 175, 55, 0.15);
                    color: #d4af37;
                    border-left: 3px solid #d4af37;
                }

            .main-content {
                margin-left: 260px;
                padding: 40px;
                width: calc(100% - 260px);
            }

            .stat-card {
                background: #141414;
                border: 1px solid rgba(212, 175, 55, 0.2);
                border-radius: 10px;
                padding: 20px;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
            }

            .stat-title {
                font-size: 0.8rem;
                color: #888;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

            .stat-value {
                font-size: 1.6rem;
                font-weight: bold;
                color: #d4af37;
                margin-top: 5px;
            }

            .panel-card {
                background-color: #121212;
                border: 1px solid rgba(212, 175, 55, 0.15);
                border-radius: 10px;
                padding: 25px;
                box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5);
            }

            .table-luxury {
                background-color: #121212 !important;
                color: #e0e0e0 !important;
            }

                .table-luxury th {
                    color: #d4af37 !important;
                    border-bottom: 2px solid #d4af37 !important;
                    font-size: 0.85rem;
                    text-transform: uppercase;
                }

                .table-luxury td {
                    border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
                }

            .lux-progress {
                background-color: #222;
                height: 8px;
                border-radius: 4px;
                overflow: hidden;
                margin-top: 5px;
            }

            .lux-progress-bar {
                background: linear-gradient(90deg, #aa7c11, #d4af37);
                height: 100%;
            }

            .top-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                border-bottom: 1px solid rgba(255, 255, 255, 0.08);
                padding-bottom: 20px;
                margin-bottom: 35px;
            }
    </style>
</head>
<body>

    <!-- SOL SABİT MENÜ (SENKRONİZE EDİLDİ 🚨) -->
    <div class="sidebar">
        <div class="sidebar-brand">ENDLESS TIME</div>

        <a href="/Admin/Product/Index" class="sidebar-link active">📊 Kontrol Paneli</a>

        @if (User.IsInRole("Admin"))
        {
            <a href="/Admin/Product/Create" class="sidebar-link">➕ Yeni Saat Ekle</a>
            <a href="/Admin/User/Index" class="sidebar-link">👥 Kullanıcılar</a>
        }

        <a href="/Admin/Order" class="sidebar-link">📦 Sipariş Raporları</a>

        <!-- Admin için Gelen Mesajlar Menüsü 🚨 -->
        @if (User.IsInRole("Admin"))
        {
            <a href="/Admin/Message" class="sidebar-link">✉️ Gelen Kutusu</a>
            <a href="/Admin/Log" class="sidebar-link">⚙️ Sistem Günlükleri</a>
        }

        <a href="/Home" class="sidebar-link" style="margin-top: auto; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 15px;">🏠 Mağaza Ön Yüzü</a>
        <a href="/Account/Logout" class="sidebar-link text-danger">🔒 Çıkış Yap</a>
    </div>

    <!-- SAĞ ANA İÇERİK ALANI -->
    <div class="main-content">

        <!-- Üst Bar -->
        <div class="top-header">
            <div>
                <h2 class="m-0 text-white" style="font-family: Georgia, serif;">Yönetim Kontrol Paneli</h2>
                <small class="text-muted">Mağaza stok ve kargo düzenleme ekranı</small>
            </div>
            <div>
                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/Product/Create" class="btn px-4 py-2"
                       style="background: linear-gradient(135deg, #d4af37, #aa7c11); color: #000; font-weight: bold; border: none; border-radius: 6px; box-shadow: 0 4px 15px rgba(212, 175, 55, 0.4); text-decoration: none; display: inline-block;">
                        ➕ Yeni Saat Ekle
                    </a>
                }
            </div>
        </div>

        <!-- İSTATİSTİK KARTLARI (Yalnızca Admin Görür) -->
        @if (User.IsInRole("Admin"))
        {
            <div class="row g-4 mb-5">
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="stat-title">⌚ Saat Koleksiyonu</div>
                        <div class="stat-value">@Model.Count() Model</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="stat-title">💵 Toplam Stok Maliyeti</div>
                        <div class="stat-value">@totalStockValue.ToString("N0") TL</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="stat-title">📈 Toplam Satış Ciro (Kâr)</div>
                        <div class="stat-value text-success">@totalSalesAmount.ToString("N0") TL</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="stat-title">👥 Kayıtlı Kullanıcılar</div>
                        <div class="stat-value">3 Aktif Üye</div>
                    </div>
                </div>
            </div>
        }

        <!-- Tablo ve Kategori Analizi -->
        <div class="row">
            <!-- Stok Listesi -->
            <div class="@(User.IsInRole("Admin") ? "col-lg-8" : "col-lg-12") mb-4">
                <div class="panel-card h-100">
                    <h4 class="mb-4 text-warning" style="font-family: Georgia, serif;">Mevcut Ürün Stokları</h4>

                    @if (TempData["DeleteError"] != null)
                    {
                        <div class="alert alert-danger bg-dark text-danger border-danger">@TempData["DeleteError"]</div>
                    }

                    <div class="table-responsive">
                        <table class="table table-luxury align-middle table-hover">
                            <thead>
                                <tr>
                                    <th>Görsel</th>
                                    <th>Model</th>
                                    <th>Kategori</th>
                                    <th>Fiyat</th>
                                    <th>Stok</th>
                                    <th>İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    var stockColor = item.Stock <= 3 ? "text-danger" : "text-success";
                                    <tr>
                                        <td>
                                            <img src="@item.ImageUrl" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px; border: 1px solid rgba(212,175,55,0.3);" />
                                        </td>
                                        <td class="fw-bold">@item.Name</td>
                                        <td><span class="badge bg-dark text-warning border border-warning">@item.Category?.Name</span></td>
                                        <td class="text-warning">@item.Price.ToString("N0") TL</td>
                                        <td class="@stockColor fw-bold">@item.Stock Adet</td>
                                        <td>
                                            <!-- Düzenleme Herkese Açık -->
                                            <a href="/Admin/Product/Edit/@item.Id" class="btn btn-sm btn-outline-warning">Düzenle ✏️</a>

                                            <!-- Ürün Silme Yetkisi (Sadece Admin Görür 🚨) -->
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <form action="/Admin/Product/Delete/@item.Id" method="post" onsubmit="return confirm('Bu saati katalogdan silmek istediğinize emin misiniz?');" style="display:inline-block;">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Sil ❌</button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Kategori Dağılımı (Yalnızca Admin Görür) -->
            @if (User.IsInRole("Admin"))
            {
                <div class="col-lg-4 mb-4">
                    <div class="panel-card h-100">
                        <h4 class="mb-4 text-warning" style="font-family: Georgia, serif;">Kategori Dağılımı</h4>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span>Automatic</span>
                                <span class="text-warning">@automaticCount</span>
                            </div>
                            <div class="lux-progress"><div class="lux-progress-bar" style="width: @(Model.Any() ? (automaticCount * 100 / Model.Count()) : 0)%"></div></div>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span>Köstekli</span>
                                <span class="text-warning">@pocketCount</span>
                            </div>
                            <div class="lux-progress"><div class="lux-progress-bar" style="width: @(Model.Any() ? (pocketCount * 100 / Model.Count()) : 0)%"></div></div>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span>Spor</span>
                                <span class="text-warning">@sportCount</span>
                            </div>
                            <div class="lux-progress"><div class="lux-progress-bar" style="width: @(Model.Any() ? (sportCount * 100 / Model.Count()) : 0)%"></div></div>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span>Akıllı</span>
                                <span class="text-warning">@smartCount</span>
                            </div>
                            <div class="lux-progress"><div class="lux-progress-bar" style="width: @(Model.Any() ? (smartCount * 100 / Model.Count()) : 0)%"></div></div>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span>Kadın</span>
                                <span class="text-warning">@womenCount</span>
                            </div>
                            <div class="lux-progress"><div class="lux-progress-bar" style="width: @(Model.Any() ? (womenCount * 100 / Model.Count()) : 0)%"></div></div>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span>Erkek</span>
                                <span class="text-warning">@menCount</span>
                            </div>
                            <div class="lux-progress"><div class="lux-progress-bar" style="width: @(Model.Any() ? (menCount * 100 / Model.Count()) : 0)%"></div></div>
                        </div>
                    </div>
                </div>
            }
        </div>

    </div>

</body>
</html>