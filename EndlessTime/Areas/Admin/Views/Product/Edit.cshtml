@model EndlessTime.Model.Entities.Product

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Endless Time - Saat Düzenle</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" />
    <style>
            body {
                background-color: #0b0b0b;
                color: #e5e5e5;
                display: flex;
            }

            .sidebar {
                width: 260px;
                background-color: #111;
                border-right: 1px solid rgba(212,175,55,0.25);
                padding: 25px 15px;
                position: fixed;
                height: 100vh;
                display: flex;
                flex-direction: column;
            }

            .sidebar-brand {
                font-family: Georgia, serif;
                font-size: 1.5rem;
                color: #d4af37;
                text-align: center;
                margin-bottom: 35px;
                letter-spacing: 2px;
                border-bottom: 1px solid rgba(212,175,55,0.2);
                padding-bottom: 15px;
            }

            .sidebar-link {
                color: #ccc;
                text-decoration: none;
                padding: 12px 15px;
                border-radius: 8px;
                margin-bottom: 8px;
                display: flex;
                align-items: center;
                gap: 12px;
            }

                .sidebar-link:hover, .sidebar-link.active {
                    background-color: rgba(212,175,55,0.15);
                    color: #d4af37;
                    border-left: 3px solid #d4af37;
                }

            .main-content {
                margin-left: 260px;
                padding: 40px;
                width: calc(100% - 260px);
            }

            .panel-card {
                background-color: #121212;
                border: 1px solid rgba(212, 175, 55, 0.15);
                border-radius: 10px;
                padding: 25px;
            }

            .form-control-luxury {
                background-color: #222 !important;
                border: 1px solid rgba(212,175,55,0.3) !important;
                color: #fff !important;
            }
    </style>
</head>
<body>

    <!-- SOL SABİT MENÜ (SENKRONİZE EDİLDİ 🚨) -->
    <div class="sidebar">
        <div class="sidebar-brand">ENDLESS TIME</div>
        <a href="/Admin/Product/Index" class="sidebar-link active">📊 Kontrol Paneli</a>

        @if (User.IsInRole("Admin"))
        {
            <a href="/Admin/Product/Create" class="sidebar-link">➕ Yeni Saat Ekle</a>
            <a href="/Admin/User/Index" class="sidebar-link">👥 Kullanıcılar</a>
        }

        <a href="/Admin/Order" class="sidebar-link">📦 Sipariş Raporları</a>

        @if (User.IsInRole("Admin"))
        {
            <a href="/Admin/Log" class="sidebar-link">⚙️ Sistem Günlükleri</a>
        }

        <a href="/Home" class="sidebar-link" style="margin-top: auto; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 15px;">🏠 Mağaza Ön Yüzü</a>
        <a href="/Account/Logout" class="sidebar-link text-danger">🔒 Çıkış Yap</a>
    </div>

    <div class="main-content">
        <div class="mb-5 border-bottom pb-3" style="border-color: rgba(212,175,55,0.2) !important;">
            <h2 style="font-family: Georgia, serif;">Saati Düzenle</h2>
            <small class="text-muted">Saat bilgilerini ve stok adetlerini güncelleyin</small>
        </div>

        <div class="card panel-card p-4" style="max-width: 800px;">
            <form action="/Admin/Product/Edit/@Model.Id" enctype="multipart/form-data" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group mb-3">
                    <label class="control-label text-warning fw-bold">Saat Adı</label>
                    <input name="Name" value="@Model.Name" class="form-control form-control-luxury" required />
                </div>

                <div class="form-group mb-3">
                    <label class="control-label text-warning fw-bold">Kategori</label>
                    <select name="CategoryId" class="form-control form-control-luxury" required>
                        @if (ViewBag.CategoriesList != null)
                        {
                            foreach (var cat in (List<EndlessTime.Model.Entities.Category>)ViewBag.CategoriesList)
                            {
                                if (cat.Id == Model.CategoryId)
                                {
                                    <option value="@cat.Id" selected="selected">@cat.Name</option>
                                }
                                else
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            }
                        }
                    </select>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label class="control-label text-warning fw-bold">Fiyat (TL)</label>
                        <input name="Price" type="number" step="0.01" value="@Model.Price.ToString("F2")" class="form-control form-control-luxury" required />
                    </div>
                    <div class="col-md-6 form-group mb-3">
                        <label class="control-label text-warning fw-bold">Stok Adedi</label>
                        <input name="Stock" type="number" value="@Model.Stock" class="form-control form-control-luxury" required />
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label text-warning fw-bold">Açıklama</label>
                    <textarea name="Description" rows="4" class="form-control form-control-luxury">@Model.Description</textarea>
                </div>

                <div class="form-group mb-3">
                    <label class="text-warning fw-bold d-block mb-2">Mevcut Görsel</label>
                    <img src="@Model.ImageUrl" style="width: 100px; height: 100px; object-fit: cover; border-radius: 6px; border: 1px solid rgba(212,175,55,0.3);" class="mb-3" />
                </div>

                <div class="form-group mb-4">
                    <label class="control-label text-warning fw-bold">Yeni Görsel Yükle (Değiştirmek istemiyorsanız boş bırakın)</label>
                    <input name="imageFile" type="file" class="form-control form-control-luxury" accept="image/*" />
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a href="/Admin/Product/Index" class="btn btn-outline-secondary">Vazgeç ve Dön</a>
                    <button type="submit" class="btn px-4 text-dark font-weight-bold" style="background: linear-gradient(135deg, #d4af37, #aa7c11); border:none;">Güncellemeyi Kaydet 💾</button>
                </div>
            </form>
        </div>
    </div>

</body>
</html>