@model EndlessTime.Model.Entities.User

@{
    ViewData["Title"] = "Ödeme Onayı";
    decimal total = ViewBag.TotalAmount;
}

<style>
    .credit-card-box {
        background: linear-gradient(135deg, #1c1c1c, #111111);
        border: 2px solid #d4af37;
        border-radius: 15px;
        color: #fff;
        padding: 25px;
        box-shadow: 0 10px 25px rgba(212, 175, 55, 0.2);
        max-width: 400px;
        margin: 0 auto 30px auto;
        font-family: 'Courier New', Courier, monospace;
    }
    
    .card-chip {
        width: 50px;
        height: 38px;
        background: linear-gradient(135deg, #ffd700, #d4af37);
        border-radius: 5px;
        margin-bottom: 20px;
    }

    .card-number-display {
        font-size: 1.4rem;
        letter-spacing: 2px;
        margin-bottom: 20px;
        color: #d4af37;
        text-shadow: 1px 1px 2px #000;
    }

    .card-holder-display {
        font-size: 0.9rem;
        text-transform: uppercase;
    }
</style>

<div class="container my-5">
    <div class="row">
        <!-- Sol Taraf: Ödeme Bilgileri Formu -->
        <div class="col-md-7">
            <div class="card-luxury p-4">
                <h3 class="text-warning mb-4" style="font-family: Georgia, serif;">Sipariş Teslimat & Ödeme</h3>
                
                <form asp-controller="Cart" asp-action="CheckoutConfirm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="totalAmount" value="@total" />

                    <h5 class="text-warning mb-3 border-bottom pb-2 border-warning">Kişisel Bilgiler</h5>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="control-label">Telefon Numarası</label>
                            <input name="phoneNumber" value="@Model.PhoneNumber" placeholder="0555 555 5555" maxlength="14" class="form-control form-control-luxury" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="control-label">Teslimat Adresi</label>
                            <input name="address" value="@Model.Address" class="form-control form-control-luxury" required />
                        </div>
                    </div>

                    <h5 class="text-warning mt-4 mb-3 border-bottom pb-2 border-warning">Kart Bilgileri</h5>
                    <div class="form-group mb-3">
                        <label class="control-label">Kart Numarası</label>
                        <input name="cardNumber" id="cc-number-input" value="@Model.CardNumber" placeholder="0000 0000 0000 0000" maxlength="19" class="form-control form-control-luxury" required />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="control-label">Kart Üzerindeki İsim</label>
                            <input name="cardHolderName" id="cc-name-input" value="@Model.CardHolderName" class="form-control form-control-luxury" required />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="control-label">Son Kul. (MM/YY)</label>
                            <input name="cardExpiry" id="cc-expiry-input" value="@Model.CardExpiry" placeholder="MM/YY" maxlength="5" class="form-control form-control-luxury" required />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="control-label">CVV</label>
                            <input name="cardCvv" id="cc-cvv-input" value="@Model.CardCvv" placeholder="***" maxlength="3" class="form-control form-control-luxury" required />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-gold w-100 py-3 mt-4 fs-5">Ödemeyi Tamamla ve Satın Al 💳</button>
                </form>
            </div>
        </div>

        <!-- Sağ Taraf: Kart Önizleme ve Tutar -->
        <div class="col-md-5">
            <div class="credit-card-box">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="card-chip"></div>
                    <span class="fw-bold text-warning" style="font-family: Georgia, serif;">EndlessTime</span>
                </div>
                <div class="card-number-display" id="cc-number">•••• •••• •••• ••••</div>
                <div class="d-flex justify-content-between">
                    <div>
                        <small class="text-muted d-block">Kart Sahibi</small>
                        <span class="card-holder-display" id="cc-name">KART SAHİBİ</span>
                    </div>
                    <div>
                        <small class="text-muted d-block">SKT</small>
                        <span id="cc-expiry">AY/YIL</span>
                    </div>
                </div>
            </div>

            <div class="card-luxury p-4 text-center mt-3">
                <h4 class="text-warning mb-3">Ödeme Özeti</h4>
                <div class="d-flex justify-content-between align-items-center">
                    <span>Çekilecek Tutar:</span>
                    <span class="text-success fw-bold fs-4">@total.ToString("N0") TL</span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const nameInput = document.getElementById('cc-name-input');
    const numberInput = document.getElementById('cc-number-input');
    const expiryInput = document.getElementById('cc-expiry-input');

    const cardName = document.getElementById('cc-name');
    const cardNumber = document.getElementById('cc-number');
    const cardExpiry = document.getElementById('cc-expiry');

    nameInput.addEventListener('input', (e) => {
        cardName.innerText = e.target.value.toUpperCase() || "KART SAHİBİ";
    });

    numberInput.addEventListener('input', (e) => {
        let value = e.target.value.replace(/\s+/g, '').replace(/[^0-9]/gi, '');
        let formatted = '';
        for (let i = 0; i < value.length; i++) {
            if (i > 0 && i % 4 === 0) formatted += ' ';
            formatted += value[i];
        }
        e.target.value = formatted;
        cardNumber.innerText = formatted || "•••• •••• •••• ••••";
    });

    expiryInput.addEventListener('input', (e) => {
        let value = e.target.value.replace(/[^0-9]/g, '');
        if (value.length >= 2) {
            e.target.value = value.slice(0, 2) + '/' + value.slice(2, 4);
        } else {
            e.target.value = value;
        }
        cardExpiry.innerText = e.target.value || "AY/YIL";
    });

    window.addEventListener('DOMContentLoaded', () => {
        if(nameInput.value) cardName.innerText = nameInput.value.toUpperCase();
        if(numberInput.value) cardNumber.innerText = numberInput.value;
        if(expiryInput.value) cardExpiry.innerText = expiryInput.value;
    });
</script>